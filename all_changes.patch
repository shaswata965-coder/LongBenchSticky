+#!/bin/bash
+# Launch 7 parallel GPU jobs for all 16 LongBench datasets.
+# CUDA_VISIBLE_DEVICES is set at shell level BEFORE Python starts.
+#
+# Usage:  bash launch_all.sh
+
+cd "$(dirname "$0")"
+export PYTHONUNBUFFERED=1
+
+GPU0_TASKS="gov_report"
+GPU1_TASKS="qmsum,trec"
+GPU2_TASKS="narrativeqa,lcc"
+GPU3_TASKS="musique,samsum"
+GPU4_TASKS="multi_news,hotpotqa,passage_count"
+GPU5_TASKS="repobench-p,triviaqa,2wikimqa"
+GPU6_TASKS="passage_retrieval_en,qasper,multifieldqa_en"
+
+echo "============================================"
+echo "Launching 7 parallel LongBench evaluations"
+echo "============================================"
+echo "GPU 0: $GPU0_TASKS"
+echo "GPU 1: $GPU1_TASKS"
+echo "GPU 2: $GPU2_TASKS"
+echo "GPU 3: $GPU3_TASKS"
+echo "GPU 4: $GPU4_TASKS"
+echo "GPU 5: $GPU5_TASKS"
+echo "GPU 6: $GPU6_TASKS"
+echo "============================================"
+
+mkdir -p logs
+
+CUDA_VISIBLE_DEVICES=0 python Results/run_longbench_sticky.py --gpu 0 --tasks "$GPU0_TASKS" > logs/gpu0.log 2>&1 &
+CUDA_VISIBLE_DEVICES=1 python Results/run_longbench_sticky.py --gpu 1 --tasks "$GPU1_TASKS" > logs/gpu1.log 2>&1 &
+CUDA_VISIBLE_DEVICES=2 python Results/run_longbench_sticky.py --gpu 2 --tasks "$GPU2_TASKS" > logs/gpu2.log 2>&1 &
+CUDA_VISIBLE_DEVICES=3 python Results/run_longbench_sticky.py --gpu 3 --tasks "$GPU3_TASKS" > logs/gpu3.log 2>&1 &
+CUDA_VISIBLE_DEVICES=4 python Results/run_longbench_sticky.py --gpu 4 --tasks "$GPU4_TASKS" > logs/gpu4.log 2>&1 &
+CUDA_VISIBLE_DEVICES=5 python Results/run_longbench_sticky.py --gpu 5 --tasks "$GPU5_TASKS" > logs/gpu5.log 2>&1 &
+CUDA_VISIBLE_DEVICES=6 python Results/run_longbench_sticky.py --gpu 6 --tasks "$GPU6_TASKS" > logs/gpu6.log 2>&1 &
+
+echo ""
+echo "All 7 jobs launched. Logs in LongBenchSticky/logs/"
+echo "Monitor:  tail -f logs/gpu*.log"
+echo "Check:    grep 'Total:' logs/gpu*.log"
+echo ""
+
+wait
+echo "============================================"
+echo "All jobs finished!"
+echo "============================================"
+grep "Total:" logs/gpu*.log
+grep "score:" logs/gpu*.log
